{
  "lexicon" : 1,
  "id" : "com.etzhayyim.fuchi.mitsuhoRailDispatch",
  "defs" : {
    "main" : {
      "type" : "record",
      "key" : "tid",
      "description" : "Food-mitsuho single-rail dispatch package (R1 dry + gated-live DESIGN). cash≡0, published=false by default, no personal scores. Live produce call to mitsuho is NOT included — only authorization plan after live_gate + disclosure open (ADR-2607177000 / 2606052300 G10).",
      "record" : {
        "type" : "object",
        "required" : [ "allocId", "subjectDid", "railKind", "providerDid", "imputedUsdMicrosYr", "phase", "published", "cashUsdMicros", "serverHeldKey", "live" ],
        "properties" : {
          "serverHeldKey" : {
            "type" : "boolean",
            "const" : false
          },
          "imputedUsdMicrosYr" : {
            "type" : "integer",
            "minimum" : 0
          },
          "railKind" : {
            "type" : "string",
            "const" : "food-mitsuho"
          },
          "allocId" : {
            "type" : "string"
          },
          "subjectDid" : {
            "type" : "string"
          },
          "scoreSurface" : {
            "type" : "array",
            "maxItems" : 0
          },
          "multiGenFacts" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "priorityStack" : {
            "type" : "array",
            "items" : {
              "type" : "string"
            }
          },
          "phase" : {
            "type" : "string",
            "enum" : [ "R1-dry", "gated-live-plan", "refused" ]
          },
          "publicPerson" : {
            "type" : "boolean"
          },
          "disclosureState" : {
            "type" : "string",
            "enum" : [ "open", "held", "exit-suspended", "n/a" ]
          },
          "cashUsdMicros" : {
            "type" : "integer",
            "const" : 0
          },
          "authorizedToPublish" : {
            "type" : "boolean",
            "description" : "true only after full live_gate; still does not call mitsuho"
          },
          "providerDid" : {
            "type" : "string",
            "const" : "did:web:etzhayyim.com:actor:mitsuho"
          },
          "refusalReason" : {
            "type" : "string"
          },
          "live" : {
            "type" : "boolean",
            "const" : false,
            "description" : "Scaffold never sets live true — mitsuho produce is out of scope here."
          },
          "published" : {
            "type" : "boolean",
            "const" : false
          }
        }
      }
    }
  }
}
