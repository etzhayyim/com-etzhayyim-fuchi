 {:R1-dry
  {:writes ["provisioningIntent published=false"]
   :reads ["route food line" "public-person? " "disclosure-gate"]
   :live false}
  :gated-live-design
  {:requires ["FUCHI_ALLOW_LIVE_PROVISION=1"
              "operator-did non-blank"
              "Council Lv6+"
              "member-signature (non-server)"
              "disclosure state ≠ held"
              "public-person? true OR L0 floor active"]
