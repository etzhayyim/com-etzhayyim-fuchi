 :rail/kind "food-mitsuho"
 :rail/provider-did "did:web:etzhayyim.com:actor:mitsuho"
 :rail/provider-kind "actor"
 :rail/label "mitsuho 瑞穂 — staple food in-kind"
 :rail/adr ["2606052300" "2607177000" "2605261000"]
